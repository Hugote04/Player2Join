rules_version = '2';

// Reglas de seguridad Firestore para Player2Join
// ================================================
// INSTRUCCIONES: Copia estas reglas en la consola de Firebase:
// 1. Ve a https://console.firebase.google.com/project/player2join-577dd/firestore/rules
// 2. Pega todo este contenido
// 3. Haz clic en "Publicar"

service cloud.firestore {
  match /databases/{database}/documents {

    // === PERFILES DE USUARIO ===
    // Colección: profiles/{uid}
    // Campos: uid, username, email, photoURL, description, createdAt
    match /profiles/{userId} {
      // Cualquier usuario autenticado puede leer perfiles
      allow read: if request.auth != null;

      // Solo el propio usuario puede crear/editar su perfil
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasAll(['uid', 'username', 'email', 'photoURL', 'description', 'createdAt'])
                    && request.resource.data.uid == userId
                    && request.resource.data.username is string
                    && request.resource.data.email is string;

      allow update: if request.auth != null
                    && request.auth.uid == userId;

      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }

    // === COLECCIÓN DE JUEGOS GUARDADOS ===
    // Colección: collections/{uid_gameId}
    // Campos: id, name, background_image, rating, released, uid, addedAt
    match /collections/{docId} {
      // Cualquier usuario autenticado puede ver colecciones (para perfil público)
      allow read: if request.auth != null;

      // Solo el dueño puede añadir a su colección
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasAll(['id', 'name', 'uid', 'addedAt']);

      // Solo el dueño puede quitar de su colección
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;

      // El dueño puede actualizar notas y estado de sus juegos
      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid;
    }

    // === JUEGOS OCULTOS DEL CATÁLOGO (Admin) ===
    // Colección: hidden_games/{gameId}
    // Campos: id, name, background_image, rating, hiddenAt, hiddenByUid
    match /hidden_games/{gameId} {
      // Cualquier usuario puede leer (para filtrar en el catálogo)
      allow read: if request.auth != null;

      // Solo admins pueden crear/eliminar (se valida en frontend por rol)
      allow create, delete: if request.auth != null;

      allow update: if false;
    }

    // === SISTEMA DE SEGUIMIENTO (follows) ===
    // Colección: follows/{followerId_followingId}
    // Campos: followerId, followingId, createdAt
    match /follows/{docId} {
      // Cualquier usuario autenticado puede leer (para contar seguidores)
      allow read: if request.auth != null;

      // Solo quien sigue puede crear el follow
      allow create: if request.auth != null
                    && request.resource.data.followerId == request.auth.uid
                    && request.resource.data.keys().hasAll(['followerId', 'followingId', 'createdAt']);

      // Solo quien sigue puede borrar (unfollow)
      allow delete: if request.auth != null
                    && resource.data.followerId == request.auth.uid;

      // No se actualiza un follow
      allow update: if false;
    }

    // === NOTIFICACIONES ===
    // Colección: notifications/{notifId}
    // Campos: type, fromUid, fromUsername, fromPhotoURL, toUid, read, createdAt
    match /notifications/{notifId} {
      // Solo el destinatario puede leer sus notificaciones
      allow read: if request.auth != null
                  && resource.data.toUid == request.auth.uid;

      // Cualquier usuario autenticado puede crear una notificación para otro
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.keys().hasAll(['type', 'fromUid', 'fromUsername', 'toUid', 'read', 'createdAt']);

      // Solo el destinatario puede actualizar (marcar como leída)
      allow update: if request.auth != null
                    && resource.data.toUid == request.auth.uid;

      // Solo el destinatario puede borrar sus notificaciones
      allow delete: if request.auth != null
                    && resource.data.toUid == request.auth.uid;
    }

    // Denegar todo lo demás
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
