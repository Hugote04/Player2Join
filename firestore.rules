rules_version = '2';

// Reglas de seguridad Firestore para Player2Join
// ================================================
// INSTRUCCIONES: Copia estas reglas en la consola de Firebase:
// 1. Ve a https://console.firebase.google.com/project/player2join-577dd/firestore/rules
// 2. Pega todo este contenido
// 3. Haz clic en "Publicar"

service cloud.firestore {
  match /databases/{database}/documents {

    // === PERFILES DE USUARIO ===
    // Colección: profiles/{uid}
    // Campos: uid, username, email, photoURL, description, createdAt
    match /profiles/{userId} {
      // Cualquier usuario autenticado puede leer perfiles
      allow read: if request.auth != null;

      // Solo el propio usuario puede crear/editar su perfil
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasAll(['uid', 'username', 'email', 'photoURL', 'description', 'createdAt'])
                    && request.resource.data.uid == userId
                    && request.resource.data.username is string
                    && request.resource.data.email is string;

      allow update: if request.auth != null
                    && request.auth.uid == userId;

      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }

    // === COLECCIÓN DE JUEGOS GUARDADOS ===
    // Colección: collections/{uid_gameId}
    // Campos: id, name, background_image, rating, released, uid, addedAt
    match /collections/{docId} {
      // Cualquier usuario autenticado puede ver colecciones (para perfil público)
      allow read: if request.auth != null;

      // Solo el dueño puede añadir a su colección
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasAll(['id', 'name', 'uid', 'addedAt']);

      // Solo el dueño puede quitar de su colección
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;

      // El dueño puede actualizar notas y estado de sus juegos
      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid;
    }

    // === JUEGOS OCULTOS DEL CATÁLOGO (Admin) ===
    // Colección: hidden_games/{gameId}
    // Campos: id, name, background_image, rating, hiddenAt, hiddenByUid
    // Seguridad: usa custom claims server-side (admin:true en el token JWT)
    match /hidden_games/{gameId} {
      // Cualquier usuario autenticado puede leer (para filtrar en el catálogo)
      allow read: if request.auth != null;

      // Solo admins verificados por custom claim server-side
      allow create, delete: if request.auth != null
                            && request.auth.token.admin == true;

      allow update: if false;
    }

    // === JUEGOS CUSTOM SUBIDOS POR USUARIOS ===
    // Colección: custom_games/{gameId}
    // Campos: id, name, description, background_image, rating, released, genres, platforms, addedByUid, addedAt, isCustom
    // Seguridad: usa custom claims server-side (admin:true en el token JWT)
    match /custom_games/{gameId} {
      // Cualquier usuario (incluso no autenticado) puede leer
      allow read: if true;

      // Solo admins verificados por custom claim server-side
      allow create: if request.auth != null
                    && request.auth.token.admin == true
                    && request.resource.data.addedByUid == request.auth.uid
                    && request.resource.data.keys().hasAll(['id', 'name', 'addedByUid', 'addedAt']);

      allow delete: if request.auth != null
                    && request.auth.token.admin == true;

      allow update: if request.auth != null
                    && request.auth.token.admin == true;
    }

    // === SISTEMA DE SEGUIMIENTO (follows) ===
    // Colección: follows/{followerId_followingId}
    // Campos: followerId, followingId, createdAt
    match /follows/{docId} {
      // Cualquier usuario autenticado puede leer (para contar seguidores)
      allow read: if request.auth != null;

      // Solo quien sigue puede crear el follow
      allow create: if request.auth != null
                    && request.resource.data.followerId == request.auth.uid
                    && request.resource.data.keys().hasAll(['followerId', 'followingId', 'createdAt']);

      // Solo quien sigue puede borrar (unfollow)
      allow delete: if request.auth != null
                    && resource.data.followerId == request.auth.uid;

      // No se actualiza un follow
      allow update: if false;
    }

    // === NOTIFICACIONES ===
    // Colección: notifications/{notifId}
    // Campos: type, fromUid, fromUsername, fromPhotoURL, toUid, read, createdAt
    match /notifications/{notifId} {
      // Solo el destinatario puede leer sus notificaciones
      allow read: if request.auth != null
                  && resource.data.toUid == request.auth.uid;

      // Cualquier usuario autenticado puede crear una notificación para otro
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.keys().hasAll(['type', 'fromUid', 'fromUsername', 'toUid', 'read', 'createdAt']);

      // Solo el destinatario puede actualizar (marcar como leída)
      allow update: if request.auth != null
                    && resource.data.toUid == request.auth.uid;

      // Solo el destinatario puede borrar sus notificaciones
      allow delete: if request.auth != null
                    && resource.data.toUid == request.auth.uid;
    }

    // === MENSAJERÍA PRIVADA (Conversaciones) ===
    // Colección: conversations/{convoId}
    // Campos: id, participants[], lastMessage, lastMessageAt, lastMessageType, lastSenderId
    match /conversations/{convoId} {
      // Solo participantes pueden leer la conversación
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;

      // Cualquier usuario autenticado puede crear una conversación (será participante)
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.keys().hasAll(['id', 'participants', 'lastMessage', 'lastMessageAt']);

      // Solo participantes pueden actualizar (enviar mensaje actualiza metadatos)
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants;

      allow delete: if false;

      // Subcolección: messages/{msgId}
      // Campos: id, conversationId, senderId, type, content, createdAt, gameData?
      match /messages/{msgId} {
        // Solo participantes de la conversación pueden leer mensajes
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convoId)).data.participants;

        // Solo participantes pueden crear mensajes y el senderId debe coincidir
        allow create: if request.auth != null
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convoId)).data.participants
                      && request.resource.data.senderId == request.auth.uid;

        // Los mensajes no se editan ni borran
        allow update, delete: if false;
      }
    }

    // Denegar todo lo demás
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
